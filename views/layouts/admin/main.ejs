<!DOCTYPE html>
<html lang="en">

<head>
  <%- include('../../partials/head') %>
    <script>
      // Place this in a global file or at the top of every dashboard <head>
      (function () {
        const token = localStorage.getItem('admin_token');
        if (!token) {
          // No token? Redirect to login immediately
          window.location.href = '/admin/login?error=unauthorized';
        }
      })();
    </script>
</head>

<body class="flex min-h-screen text-slate-900">

  <aside class="sidebar" data-side="left" aria-hidden="false">
    <nav aria-label="Sidebar navigation">
      <section class="scrollbar">
        <div role="group" aria-labelledby="group-label-content-1" class="bg-blue-900">
          <h3 id="group-label-content-1">Getting started</h3>

          <aside class="sidebar bg-slate-900 text-slate-300 w-64 border-r border-slate-800" data-side="left"
            aria-hidden="false">

            <div class="flex items-center gap-3 px-6 py-8 border-b border-slate-800/50">
              <div class="flex h-8 w-8 items-center justify-center rounded bg-blue-600 text-white font-bold">DA</div>
              <div class="flex flex-col">
                <span class="text-lg font-bold tracking-tight text-white leading-none">DA Multi Service</span>
                <span class="text-[10px] uppercase tracking-widest text-slate-500 font-semibold mt-1">Admin
                  Portal</span>
              </div>
            </div>

            <nav aria-label="Sidebar navigation" class="mt-4 pb-10 bg-blue-900">
              <section class="scrollbar">

                <div role="group" class="px-3 mb-6">
                  <h3 class="px-3 text-[11px] font-bold uppercase tracking-wider text-blue-400 mb-2">Monitoring</h3>
                  <ul class="space-y-1">
                    <li>
                      <a href="/admin/summary"
                        class="flex items-center gap-3 px-3 py-2 rounded-md transition-colors <%= (locals.activePage === 'summary') ? 'bg-blue-600 text-white' : 'hover:bg-slate-800 hover:text-white' %>">
                        <i data-lucide="layout-dashboard" class="w-4 h-4 text-white"></i>
                        <span class="text-sm font-medium text-white">Dashboard Summary</span>
                      </a>
                    </li>
                    <li>
                      <a href="/admin/reports"
                        class="flex items-center gap-3 px-3 py-2 rounded-md transition-colors <%= (locals.activePage === 'reports') ? 'bg-blue-600 text-white' : 'hover:bg-slate-800 hover:text-white' %>">
                        <i data-lucide="bar-chart-3" class="w-4 h-4 text-white"></i>
                        <span class="text-sm font-medium text-white">Reports</span>
                      </a>
                    </li>
                  </ul>
                </div>

                <div role="group" class="px-3 mb-6">
                  <h3 class="px-3 text-[11px] font-bold uppercase tracking-wider text-blue-400 mb-2">Organizations</h3>
                  <ul class="space-y-1">
                    <li>
                      <a href="/admin/businesses"
                        class="flex items-center gap-3 px-3 py-2 rounded-md transition-colors <%= (locals.activePage === 'businesses') ? 'bg-blue-600 text-white' : 'hover:bg-slate-800 hover:text-white' %>">
                        <i data-lucide="building-2" class="w-4 h-4 text-white"></i>
                        <span class="text-sm font-medium text-white">Registered Businesses</span>
                      </a>
                    </li>
                    <li>
                      <a href="/admin/users"
                        class="flex items-center gap-3 px-3 py-2 rounded-md transition-colors <%= (locals.activePage === 'users') ? 'bg-blue-600 text-white' : 'hover:bg-slate-800 hover:text-white' %>">
                        <i data-lucide="users" class="w-4 h-4 text-white"></i>
                        <span class="text-sm font-medium text-white">Manage App Users</span>
                      </a>
                    </li>
                  </ul>
                </div>

                <div role="group" class="px-3 mb-6">
                  <h3 class="px-3 text-[11px] font-bold uppercase tracking-wider text-blue-400 mb-2">Service Desk</h3>
                  <ul class="space-y-1">
                    <li>
                      <a href="/admin/faults"
                        class="flex items-center gap-3 px-3 py-2 rounded-md transition-colors <%= (locals.activePage === 'faults') ? 'bg-blue-600 text-white' : 'hover:bg-slate-800 hover:text-white' %>">
                        <i data-lucide="alert-circle" class="w-4 h-4 text-white"></i>
                        <span class="text-sm font-medium text-white">Fault Management</span>
                        <span
                          class="ml-auto bg-red-500 text-white text-[10px] font-bold px-1.5 py-0.5 rounded">12</span>
                      </a>
                    </li>
                    <li>
                      <a href="/admin/services"
                        class="flex items-center gap-3 px-3 py-2 rounded-md transition-colors <%= (locals.activePage === 'services') ? 'bg-blue-600 text-white' : 'hover:bg-slate-800 hover:text-white' %>">
                        <i data-lucide="book-open" class="w-4 h-4 text-white"></i>
                        <span class="text-sm font-medium text-white">Service Catalog</span>
                      </a>
                    </li>
                  </ul>
                </div>

                <div role="group" class="px-3 mb-6">
                  <h3 class="px-3 text-[11px] font-bold uppercase tracking-wider text-blue-400 mb-2">Access Control
                  </h3>
                  <ul class="space-y-1">
                    <li>
                      <a href="/admin/system-users"
                        class="flex items-center gap-3 px-3 py-2 rounded-md transition-colors <%= (locals.activePage === 'system-users') ? 'bg-blue-600 text-white' : 'hover:bg-slate-800 hover:text-white' %>">
                        <i data-lucide="users" class="w-4 h-4 text-white"></i>
                        <span class="text-sm font-medium text-white">System Users</span>
                      </a>
                    </li>
                  </ul>
                </div>

                <!-- <div role="group" class="px-3">
                  <h3 class="px-3 text-[11px] font-bold uppercase tracking-wider text-blue-400 mb-2">System</h3>
                  <ul class="space-y-1">
                    <li>
                      <a href="/admin/settings"
                        class="flex items-center gap-3 px-3 py-2 rounded-md transition-colors <%= (locals.activePage === 'settings') ? 'bg-blue-600 text-white' : 'hover:bg-slate-800 hover:text-white' %>">
                        <i data-lucide="settings" class="w-4 h-4 text-white"></i>
                        <span class="text-sm font-medium text-white">Global Settings</span>
                      </a>
                    </li>
                  </ul>
                </div> -->

                 <div class="mt-auto p-4">
                <div class="flex items-center gap-3 px-2 mb-4">
                  <div class="relative">
                    <div id="user-avatar"
                      class="h-9 w-9 rounded-full bg-blue-600 flex items-center justify-center text-white font-bold text-sm border-2 border-slate-800">
                    </div>
                    <span
                      class="absolute bottom-0 right-0 h-2.5 w-2.5 rounded-full bg-emerald-500 border-2 border-slate-900"></span>
                  </div>
                  <div class="flex flex-col overflow-hidden">
                    <span id="user-display-name" class="text-sm font-bold text-white truncate">Admin User</span>
                    <span class="text-[10px] text-slate-500 uppercase font-bold">Super Admin</span>
                  </div>
                </div>

                <button onclick="handleSignOut()"
                  class="flex w-full items-center gap-3 px-3 py-2 rounded-md text-slate-400 hover:bg-rose-500/10 hover:text-rose-500 transition-all group">
                  <i data-lucide="log-out" class="w-4 h-4 group-hover:translate-x-1 transition-transform"></i>
                  <span class="text-sm font-medium">Sign Out</span>
                </button>
              </div>

              </section>
             

            </nav>

          </aside>

          <script>
            lucide.createIcons();
          </script>
        </div>
      </section>
    </nav>
  </aside>

  <main class="flex-1 flex flex-col">
    <button type="button" class="btn-secondary" onclick="document.dispatchEvent(new CustomEvent('basecoat:sidebar'))">☰
      Menu</button>
    <div class="flex-1 overflow-y-auto p-8">
      <%- body %>
    </div>

  </main>

  <script>
  // Populate User Info
  $(document).ready(function() {
      // Assuming you saved 'user_name' in localStorage during login
      const userName = localStorage.getItem('admin_name') || 'Administrator';
      const initial = userName.charAt(0).toUpperCase();
      
      $('#user-display-name').text(userName);
      $('#user-avatar').text(initial);
      
      lucide.createIcons();
  });

  // Handle Logout
  function handleSignOut() {
      if (confirm('Are you sure you want to sign out?')) {
          // 1. Clear tokens/user data
          localStorage.removeItem('admin_token');
          localStorage.removeItem('admin_name');
          
          // 2. Optional: Call an API logout endpoint if needed
          
          // 3. Redirect to login
          window.location.href = '/admin/login?message=signed_out';
      }
  }
</script>
</body>

</html>