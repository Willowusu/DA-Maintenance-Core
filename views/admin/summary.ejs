<script>
  // Wait for DOM to load
  document.addEventListener('DOMContentLoaded', function() {
    const ctx = document.getElementById('faultsChart').getContext('2d');
    
    new Chart(ctx, {
      type: 'bar',
      data: {
        labels: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun'],
        datasets: [{
          label: 'Reported',
          data: [120, 190, 150, 210, 180, 240],
          backgroundColor: '#2563eb', // blue-600
          borderRadius: 6,
          borderSkipped: false,
        }, {
          label: 'Resolved',
          data: [100, 170, 140, 190, 160, 210],
          backgroundColor: '#e2e8f0', // slate-200
          borderRadius: 6,
          borderSkipped: false,
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { display: false }, // We built a custom legend in the header
          tooltip: {
            backgroundColor: '#1e293b',
            padding: 12,
            titleFont: { size: 14, weight: 'bold' },
            bodyFont: { size: 13 },
            cornerRadius: 8,
            displayColors: true
          }
        },
        scales: {
          x: {
            grid: { display: false },
            ticks: { color: '#64748b' }
          },
          y: {
            border: { dash: [4, 4] },
            grid: { color: '#f1f5f9' },
            ticks: { color: '#64748b', stepSize: 50 }
          }
        }
      }
    });
  });
</script>