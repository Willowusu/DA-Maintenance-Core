  </div>

  <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4 w-full">
    <!-- Total Revenue -->
    <!-- <div class="card bg-white p-6 shadow-sm border border-slate-200 rounded-xl">
      <div class="flex items-center justify-between pb-2">
        <h3 class="text-sm font-medium text-slate-500">Total Revenue</h3>
        <i data-lucide="dollar-sign" class="w-4 h-4 text-slate-400"></i>
      </div>
      <div class="text-3xl font-bold">$<%= stats.totalRevenue.toLocaleString() %></div>
    </div> -->

    <!-- Active Faults -->
    <div class="card bg-white p-6 shadow-sm border border-slate-200 rounded-xl">
      <div class="flex items-center justify-between pb-2">
        <h3 class="text-sm font-medium text-slate-500">Active Faults</h3>
