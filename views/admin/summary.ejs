      </div>
      <div class="text-3xl font-bold"><%= stats.activeFaults %></div>
    </div>

    <!-- Businesses -->
    <div class="card bg-white p-6 shadow-sm border border-slate-200 rounded-xl">
      <div class="flex items-center justify-between pb-2">
        <h3 class="text-sm font-medium text-slate-500">Active Businesses</h3>
