    <!-- Success Rate -->
    <!-- <div class="card bg-white p-6 shadow-sm border border-slate-200 rounded-xl">
      <div class="flex items-center justify-between pb-2">
        <h3 class="text-sm font-medium text-slate-500">Service Success</h3>
        <i data-lucide="star" class="w-4 h-4 text-slate-400"></i>
      </div>
      <div class="text-3xl font-bold"><%= stats.successRate %>%</div>
    </div> -->
  </div>
