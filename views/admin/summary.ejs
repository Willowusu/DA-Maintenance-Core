<!-- Chart Section -->
<div class="card bg-white shadow-sm border border-slate-200 rounded-xl mt-8">
  <header class="p-6 border-b border-slate-100 flex items-center justify-between">
    <div>
      <h2 class="text-lg font-semibold text-slate-900">Fault Performance</h2>
    </div>
  </header>
  <section class="p-6">
    <div class="relative w-full h-[350px]">
      <canvas id="faultsChart"></canvas>
    </div>
  </section>
</div>

<!-- Recent Faults Table -->
<div class="card bg-white shadow-sm border border-slate-200 rounded-xl mt-8 overflow-hidden">
  <div class="overflow-x-auto">
    <table class="w-full text-left">
      <thead>
        <tr class="bg-slate-50 border-b border-slate-100">
          <th class="px-6 py-4 text-xs font-semibold text-slate-500">BUSINESS</th>
          <th class="px-6 py-4 text-xs font-semibold text-slate-500">SERVICE</th>
          <th class="px-6 py-4 text-xs font-semibold text-slate-500">STATUS</th>
          <th class="px-6 py-4 text-xs font-semibold text-slate-500">DATE</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <% recentFaults.forEach(fault => { %>
          <tr class="hover:bg-slate-50">
            <td class="px-6 py-4">
              <div class="font-medium text-slate-900"><%= fault.business_id.name %></div>
            </td>
            <td class="px-6 py-4 text-sm text-slate-600">
              <%= fault.service_id.name %>
            </td>
            <td class="px-6 py-4">
              <span class="px-2 py-1 rounded-full text-xs font-medium 
                <%= fault.status === 'resolved' ? 'bg-emerald-50 text-emerald-700' : 'bg-amber-50 text-amber-700' %>">
                <%= fault.status.replace('_', ' ') %>
              </span>
            </td>
            <td class="px-6 py-4 text-sm text-slate-500">
              <%= new Date(fault.createdAt).toLocaleDateString() %>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    // Inject data from EJS
    const chartData = <%- JSON.stringify(chartData) %>;
    
    const ctx = document.getElementById('faultsChart').getContext('2d');
    new Chart(ctx, {
      type: 'bar',
      data: {
        labels: chartData.labels,
        datasets: [{
          label: 'Reported',
          data: chartData.reported,
          backgroundColor: '#2563eb',
          borderRadius: 6
        }, {
          label: 'Resolved',
          data: chartData.resolved,
          backgroundColor: '#e2e8f0',
          borderRadius: 6
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        scales: {
          y: { beginAtZero: true }
        }
      }
    });

    // Fetch Auth Info
    fetch('/api/v1/auth/me')
      .then(res => res.json())
      .then(response => {
        if (response.status === 'success') {
          localStorage.setItem('user', JSON.stringify(response.data));
          console.log('User session initialized');
        }
      })
      .catch(err => console.error('Auth sync failed'));
  });
</script>