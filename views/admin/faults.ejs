<div class="w-full space-y-6">
  <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
    <div>
      <h1 class="text-3xl font-bold tracking-tight text-slate-900">Fault Reports</h1>
      <p class="text-slate-500">Track, approve, and manage service maintenance requests.</p>
    </div>
    <div class="flex items-center gap-2">
       <button class="btn inline-flex items-center justify-center gap-2 bg-white border border-slate-200 text-slate-700 px-4 py-2 rounded-lg hover:bg-slate-50 transition-all font-medium shadow-sm">
        <i data-lucide="download" class="w-4 h-4"></i> Export CSV
      </button>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-4 bg-white p-4 rounded-xl border border-slate-200 shadow-sm">
    <div class="relative lg:col-span-2">
      <i data-lucide="search" class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400"></i>
      <input type="text" placeholder="Search by description or business..." 
             class="w-full pl-10 pr-4 py-2 border border-slate-200 rounded-lg focus:ring-2 focus:ring-slate-900 outline-none text-sm">
    </div>
    <select class="px-3 py-2 border border-slate-200 rounded-lg text-sm outline-none focus:ring-2 focus:ring-slate-900 bg-white">
      <option value="">All Statuses</option>
      <option value="reported">Reported</option>
      <option value="approved">Approved</option>
      <option value="in_progress">In Progress</option>
      <option value="resolved">Resolved</option>
    </select>
    <input type="date" class="px-3 py-2 border border-slate-200 rounded-lg text-sm outline-none focus:ring-2 focus:ring-slate-900">
    <button class="bg-slate-900 text-white rounded-lg px-4 py-2 text-sm font-medium hover:bg-slate-800">Apply Filters</button>
  </div>

  <div class="card bg-white shadow-sm border border-slate-200 rounded-xl overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-left border-collapse">
        <thead>
          <tr class="bg-slate-50/50 border-b border-slate-100">
            <th class="px-6 py-4 text-xs font-semibold uppercase text-slate-500">Fault & Business</th>
            <th class="px-6 py-4 text-xs font-semibold uppercase text-slate-500">Service</th>
            <th class="px-6 py-4 text-xs font-semibold uppercase text-slate-500">Status</th>
            <th class="px-6 py-4 text-xs font-semibold uppercase text-slate-500">Reported Date</th>
            <th class="px-6 py-4 text-xs font-semibold uppercase text-slate-500 text-right">Action</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <tr class="hover:bg-slate-50/50 transition-colors">
            <td class="px-6 py-4">
              <div class="font-semibold text-slate-900 truncate max-w-[200px]">Broken AC Unit in Server Room</div>
              <div class="text-xs text-slate-500">TechHub Offices</div>
            </td>
            <td class="px-6 py-4">
              <span class="text-sm px-2 py-1 bg-blue-50 text-blue-700 rounded-md font-medium">HVAC Maintenance</span>
            </td>
            <td class="px-6 py-4">
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-amber-50 text-amber-700 border border-amber-100">
                In Progress
              </span>
            </td>
            <td class="px-6 py-4 text-sm text-slate-500">March 10, 2026</td>
            <td class="px-6 py-4 text-right">
              <button onclick="openModal('fault-123')" class="inline-flex items-center gap-1.5 text-sm font-bold text-blue-600 hover:text-blue-800">
                <i data-lucide="eye" class="w-4 h-4"></i> View
              </button>
            </td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</div>