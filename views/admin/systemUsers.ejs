<div class="w-full space-y-6">
  <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
    <div>
      <h1 class="text-3xl font-bold tracking-tight text-slate-900">System User Management</h1>
      <p class="text-slate-500">Manage access levels for system admin users.</p>
    </div>
    <div class="flex items-center gap-2">
       <button class="btn inline-flex items-center justify-center gap-2 bg-white border border-slate-200 text-slate-700 px-4 py-2 rounded-lg hover:bg-slate-50 transition-all font-medium shadow-sm">
        <i data-lucide="download" class="w-4 h-4"></i>
        Export to CSV
      </button>
      <button class="btn inline-flex items-center justify-center gap-2 bg-slate-900 text-white px-4 py-2 rounded-lg hover:bg-slate-800 transition-all font-medium shadow-sm">
        <i data-lucide="user-plus" class="w-4 h-4"></i>
        Invite User
      </button>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-4 gap-4 bg-white p-4 rounded-xl border border-slate-200 shadow-sm">
    <div class="relative lg:col-span-1">
      <i data-lucide="search" class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400"></i>
      <input type="text" placeholder="Search name or phone..." 
             class="w-full pl-10 pr-4 py-2 border border-slate-200 rounded-lg focus:ring-2 focus:ring-slate-900 outline-none text-sm">
    </div>

    <div class="relative">
      <label class="absolute -top-2 left-3 bg-white px-1 text-[10px] font-bold text-slate-400 uppercase">Created From</label>
      <input type="date" class="w-full px-3 py-2 border border-slate-200 rounded-lg focus:ring-2 focus:ring-slate-900 outline-none text-sm">
    </div>

    <div class="relative">
      <label class="absolute -top-2 left-3 bg-white px-1 text-[10px] font-bold text-slate-400 uppercase">Created To</label>
      <input type="date" class="w-full px-3 py-2 border border-slate-200 rounded-lg focus:ring-2 focus:ring-slate-900 outline-none text-sm">
    </div>

    <div class="relative">
      <select class="w-full px-3 py-2 border border-slate-200 rounded-lg focus:ring-2 focus:ring-slate-900 outline-none text-sm appearance-none bg-white">
        <option value="">All Roles</option>
        <option value="business_admin">Business Admin</option>
        <option value="reporter">Reporter</option>
      </select>
      <i data-lucide="chevron-down" class="absolute right-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400 pointer-events-none"></i>
    </div>
  </div>

  <div class="card bg-white shadow-sm border border-slate-200 rounded-xl overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-left border-collapse">
        <thead>
          <tr class="bg-slate-50/50 border-b border-slate-100">
            <th class="px-6 py-4 text-xs font-semibold uppercase tracking-wider text-slate-500">User Details</th>
            <th class="px-6 py-4 text-xs font-semibold uppercase tracking-wider text-slate-500">Assigned Business</th>
            <th class="px-6 py-4 text-xs font-semibold uppercase tracking-wider text-slate-500">Role</th>
            <th class="px-6 py-4 text-xs font-semibold uppercase tracking-wider text-slate-500">Date Created</th>
            <th class="px-6 py-4 text-xs font-semibold uppercase tracking-wider text-slate-500">Status</th>
            <th class="px-6 py-4 text-xs font-semibold uppercase tracking-wider text-slate-500 text-right">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100 text-sm">
          <tr class="hover:bg-slate-50/50 transition-colors">
            <td class="px-6 py-4 font-medium text-slate-900">John Doe</td>
            <td class="px-6 py-4 text-slate-600 font-medium text-slate-700">Main Street Plaza</td>
            <td class="px-6 py-4"><span class="px-2 py-1 rounded bg-purple-50 text-purple-700 text-xs font-bold uppercase">Super Admin</span></td>
            <td class="px-6 py-4 text-slate-600">2024-05-15</td>
            <td class="px-6 py-4"><span class="text-emerald-600 font-semibold italic text-xs">Active</span></td>
            <td class="px-6 py-4 text-right">
                <button class="text-slate-400 hover:text-slate-900"><i data-lucide="more-vertical" class="w-4 h-4"></i></button>
            </td>
          </tr>
        </tbody>
      </table>
    </div>

    <footer class="p-4 border-t border-slate-100 bg-slate-50/30 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-slate-500 font-medium">
        Showing <span class="text-slate-900">1</span> to <span class="text-slate-900">10</span> of <span class="text-slate-900">48</span> users
      </p>
      <div class="flex items-center gap-1">
        <button class="p-2 border border-slate-200 rounded-lg bg-white hover:bg-slate-50 disabled:opacity-50 disabled:cursor-not-allowed">
          <i data-lucide="chevron-left" class="w-4 h-4"></i>
        </button>
        <button class="px-3 py-1 border border-slate-900 rounded-lg bg-slate-900 text-white text-xs font-bold">1</button>
        <button class="px-3 py-1 border border-slate-200 rounded-lg bg-white text-slate-600 hover:bg-slate-50 text-xs font-bold">2</button>
        <button class="px-3 py-1 border border-slate-200 rounded-lg bg-white text-slate-600 hover:bg-slate-50 text-xs font-bold">3</button>
        <button class="p-2 border border-slate-200 rounded-lg bg-white hover:bg-slate-50">
          <i data-lucide="chevron-right" class="w-4 h-4"></i>
        </button>
      </div>
    </footer>
  </div>
</div>