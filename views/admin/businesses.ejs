<style>
        .alert { @apply flex gap-3 p-4 rounded-lg bg-emerald-50 text-emerald-700 border border-emerald-100 items-start; }
        .alert-destructive { @apply flex gap-3 p-4 rounded-lg bg-rose-50 text-rose-700 border border-rose-100 items-start; }
    </style>

<div class="w-full max-w-7xl mx-auto space-y-6">
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
        <div>
            <h1 class="text-3xl font-bold tracking-tight text-slate-900">Businesses</h1>
            <p class="text-slate-500">Manage partners, track staff, and monitor reported faults.</p>
        </div>
        <button onclick="toggleModal(true)" class="inline-flex items-center justify-center gap-2 bg-slate-900 text-white px-5 py-2.5 rounded-lg hover:bg-slate-800 transition-all font-medium shadow-sm">
            <i data-lucide="plus-circle" class="w-5 h-5"></i> Add New Business
        </button>
    </div>

    <div id="alert-container" class="hidden transition-all duration-300"></div>

    <div class="flex flex-col md:flex-row gap-4 items-center justify-between bg-white p-4 rounded-xl border border-slate-200 shadow-sm">
        <div class="relative w-full md:w-96">
            <i data-lucide="search" class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400"></i>
            <input type="text" id="business-search" placeholder="Search by name or email..." 
                   class="w-full pl-10 pr-4 py-2 border border-slate-200 rounded-lg focus:ring-2 focus:ring-slate-900 outline-none text-sm">
        </div>
        <button id="btn-export" class="inline-flex items-center gap-2 px-4 py-2 border border-slate-200 rounded-lg text-sm font-medium hover:bg-slate-50 transition-colors">
            <i data-lucide="download" class="w-4 h-4"></i> Export CSV
        </button>
    </div>

    <div class="card bg-white shadow-sm border border-slate-200 rounded-xl overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-slate-50/50 border-b border-slate-100">
                        <th class="px-6 py-4 text-xs font-semibold uppercase text-slate-500">Business & Location</th>
                        <th class="px-6 py-4 text-xs font-semibold uppercase text-slate-500 text-center">Stats</th>
                        <th class="px-6 py-4 text-xs font-semibold uppercase text-slate-500">Contact</th>
                        <th class="px-6 py-4 text-xs font-semibold uppercase text-slate-500 text-right">Actions</th>
                    </tr>
                </thead>
                <tbody id="business-table-body" class="divide-y divide-slate-100"></tbody>
            </table>
        </div>
        <div class="bg-slate-50/50 border-t border-slate-100 px-6 py-4 flex items-center justify-between">
            <p class="text-sm text-slate-500">Showing <span id="page-range" class="font-medium text-slate-900"></span> of <span id="total-count"></span></p>
            <div class="flex gap-2">
                <button id="prev-page" class="p-2 border rounded-lg hover:bg-white disabled:opacity-50"><i data-lucide="chevron-left" class="w-4 h-4"></i></button>
                <button id="next-page" class="p-2 border rounded-lg hover:bg-white disabled:opacity-50"><i data-lucide="chevron-right" class="w-4 h-4"></i></button>
            </div>
        </div>
    </div>
</div>

<div id="add-business-modal" class="fixed inset-0 z-50 hidden flex items-center justify-center bg-slate-900/60 backdrop-blur-sm p-4">
    <div class="bg-white w-full max-w-lg rounded-2xl shadow-2xl p-6">
        <div class="flex justify-between items-center mb-6">
            <h3 class="text-xl font-bold">Register Business</h3>
            <button onclick="toggleModal(false)"><i data-lucide="x" class="w-5 h-5 text-slate-400"></i></button>
        </div>
        <form id="add-business-form" class="space-y-4">
            <div>
                <label class="block text-sm font-medium text-slate-700 mb-1">Business Name</label>
                <input type="text" id="new-biz-name" required class="w-full px-3 py-2 border rounded-lg focus:ring-2 focus:ring-slate-900 outline-none">
            </div>
            <div>
                <label class="block text-sm font-medium text-slate-700 mb-1">Address</label>
                <textarea id="new-biz-address" rows="2" required class="w-full px-3 py-2 border rounded-lg focus:ring-2 focus:ring-slate-900 outline-none"></textarea>
            </div>
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">Contact Person</label>
                    <input type="text" id="new-biz-contact" required class="w-full px-3 py-2 border rounded-lg focus:ring-2 focus:ring-slate-900 outline-none">
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">Phone</label>
                    <input type="tel" id="new-biz-phone" required class="w-full px-3 py-2 border rounded-lg focus:ring-2 focus:ring-slate-900 outline-none">
                </div>
            </div>
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">Email</label>
                    <input type="email" id="new-biz-email" required class="w-full px-3 py-2 border rounded-lg focus:ring-2 focus:ring-slate-900 outline-none">
                </div>
            </div>
            <div class="flex gap-3 pt-4">
                <button type="button" onclick="toggleModal(false)" class="flex-1 py-2.5 border rounded-lg font-medium">Cancel</button>
                <button type="submit" id="btn-save" class="flex-1 py-2.5 bg-slate-900 text-white rounded-lg font-medium shadow-lg hover:bg-slate-800">Save Business</button>
            </div>
        </form>
    </div>
</div>

<script>
    let allBusinesses = [];
    let filteredBusinesses = [];
    let currentPage = 1;
    const itemsPerPage = 8;

    const showAlert = (type, title, desc) => {
        const isErr = type === 'danger' || type === 'error';
        const html = `
            <div class="${isErr ? 'alert-destructive' : 'alert'} animate-in slide-in-from-top-2">
                <i data-lucide="${isErr ? 'alert-circle' : 'check-circle'}" class="w-5 h-5"></i>
                <div><h2 class="font-bold text-sm">${title}</h2><p class="text-xs">${desc}</p></div>
            </div>`;
        $('#alert-container').html(html).show();
        lucide.createIcons();
        setTimeout(() => $('#alert-container').fadeOut(), 4000);
    };

    function toggleModal(show) {
        $('#add-business-modal').toggleClass('hidden', !show);
        if(!show) $('#add-business-form')[0].reset();
    }

    function fetchData() {
        $.ajax({
            url: '/api/v1/businesses',
            method: 'GET',
            success: (res) => {
                allBusinesses = res.data;
                applyFilters();
            },
            error: () => showAlert('error', 'Network Error', 'Could not sync with the server.')
        });
    }

    function applyFilters() {
        const query = $('#business-search').val().toLowerCase();
        filteredBusinesses = allBusinesses.filter(b => 
            b.name.toLowerCase().includes(query) || b.email.toLowerCase().includes(query)
        );
        currentPage = 1;
        updateUI();
    }

    function updateUI() {
        const start = (currentPage - 1) * itemsPerPage;
        const end = start + itemsPerPage;
        const items = filteredBusinesses.slice(start, end);
        const tbody = $('#business-table-body').empty();

        if(!items.length) tbody.append('<tr><td colspan="4" class="py-10 text-center text-slate-400 italic">No partners found.</td></tr>');

        items.forEach(b => {
            tbody.append(`
                <tr class="hover:bg-slate-50 transition-colors">
                    <td class="px-6 py-4">
                        <div class="font-bold text-slate-900">${b.name}</div>
                        <div class="text-[11px] text-slate-400 mt-1 flex items-center gap-1">
                            <i data-lucide="map-pin" class="w-3 h-3"></i> ${b.address}
                        </div>
                    </td>
                    <td class="px-6 py-4">
                        <div class="flex items-center justify-center gap-4">
                            <div class="text-center">
                                <span class="block text-sm font-bold">${b.staff_count || 0}</span>
                                <span class="text-[9px] uppercase font-bold text-slate-400">Staff</span>
                            </div>
                            <div class="text-center">
                                <span class="block text-sm font-bold text-orange-600">${b.pending_faults || 0}</span>
                                <span class="text-[9px] uppercase font-bold text-slate-400">Faults</span>
                            </div>
                        </div>
                    </td>
                    <td class="px-6 py-4 text-sm">
                        <div class="font-medium text-slate-700">${b.contact_person}</div>
                        <div class="text-xs text-slate-400">${b.email}</div>
                    </td>
                    <td class="px-6 py-4 text-right">
                        <button onclick="manageStaff('${b._id}')" class="p-2 hover:bg-slate-100 rounded-lg text-slate-400 hover:text-slate-900"><i data-lucide="users" class="w-4 h-4"></i></button>
                    </td>
                </tr>
            `);
        });

        const total = filteredBusinesses.length;
        $('#page-range').text(`${total === 0 ? 0 : start + 1}-${Math.min(end, total)}`);
        $('#total-count').text(total);
        $('#prev-page').prop('disabled', currentPage === 1);
        $('#next-page').prop('disabled', end >= total);
        lucide.createIcons();
    }

    $('#add-business-form').on('submit', function(e) {
        e.preventDefault();
        const btn = $('#btn-save');
        const payload = {
            name: $('#new-biz-name').val(),
            address: $('#new-biz-address').val(),
            contact_person: $('#new-biz-contact').val(),
            phone: $('#new-biz-phone').val(),
            email: $('#new-biz-email').val()
        };

        btn.prop('disabled', true).text('Saving...');
        $.ajax({
            url: '/api/v1/businesses',
            method: 'POST',
            contentType: 'application/json',
            data: JSON.stringify(payload),
            success: () => {
                showAlert('success', 'Business Created', 'The record has been updated.');
                toggleModal(false);
                fetchData();
            },
            error: (err) => {
                showAlert('error', 'Error', err.responseJSON?.message || 'Update failed.');
                btn.prop('disabled', false).text('Save Business');
            }
        });
    });

    $('#business-search').on('input', applyFilters);
    $('#prev-page').click(() => { if(currentPage > 1) { currentPage--; updateUI(); } });
    $('#next-page').click(() => { if((currentPage * itemsPerPage) < filteredBusinesses.length) { currentPage++; updateUI(); } });
    
    $(document).ready(fetchData);
</script>