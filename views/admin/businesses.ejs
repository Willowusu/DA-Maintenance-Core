<div class="w-full space-y-6">
  <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
    <div>
      <h1 class="text-3xl font-bold tracking-tight text-slate-900">Businesses</h1>
      <p class="text-slate-500">Manage and contact all registered business partners.</p>
    </div>
    <button class="btn inline-flex items-center justify-center gap-2 bg-slate-900 text-white px-4 py-2 rounded-lg hover:bg-slate-800 transition-all font-medium">
      <i data-lucide="plus" class="w-4 h-4"></i>
      Add New Business
    </button>
  </div>

  <div class="flex flex-col md:flex-row gap-4 items-center justify-between bg-white p-4 rounded-xl border border-slate-200 shadow-sm">
    <div class="relative w-full md:w-96">
      <i data-lucide="search" class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400"></i>
      <input type="text" placeholder="Search by name, email, or contact..." 
             class="w-full pl-10 pr-4 py-2 border border-slate-200 rounded-lg focus:ring-2 focus:ring-slate-900 outline-none text-sm">
    </div>
    <div class="flex items-center gap-2 w-full md:w-auto">
      <button class="flex-1 md:flex-none inline-flex items-center justify-center gap-2 px-3 py-2 border border-slate-200 rounded-lg text-sm font-medium hover:bg-slate-50">
        <i data-lucide="filter" class="w-4 h-4"></i> Filter
      </button>
      <button class="flex-1 md:flex-none inline-flex items-center justify-center gap-2 px-3 py-2 border border-slate-200 rounded-lg text-sm font-medium hover:bg-slate-50">
        <i data-lucide="download" class="w-4 h-4"></i> Export
      </button>
    </div>
  </div>

  <div class="card bg-white shadow-sm border border-slate-200 rounded-xl overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-left border-collapse">
        <thead>
          <tr class="bg-slate-50/50 border-b border-slate-100">
            <th class="px-6 py-4 text-xs font-semibold uppercase text-slate-500">Business Details</th>
            <th class="px-6 py-4 text-xs font-semibold uppercase text-slate-500">Contact Person</th>
            <th class="px-6 py-4 text-xs font-semibold uppercase text-slate-500">Communication</th>
            <th class="px-6 py-4 text-xs font-semibold uppercase text-slate-500">Joined Date</th>
            <th class="px-6 py-4 text-xs font-semibold uppercase text-slate-500 text-right">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <tr class="hover:bg-slate-50/50 transition-colors group">
            <td class="px-6 py-4">
              <div class="font-bold text-slate-900 leading-tight">Elite Manufacturing Ltd</div>
              <div class="text-xs text-slate-500 mt-0.5 flex items-center gap-1">
                <i data-lucide="map-pin" class="w-3 h-3"></i> 45 Industrial Way, North Sector
              </div>
            </td>
            <td class="px-6 py-4">
              <div class="text-sm font-medium text-slate-700">Sarah Jenkins</div>
              <div class="text-xs text-slate-400 italic">Operations Manager</div>
            </td>
            <td class="px-6 py-4">
              <div class="flex flex-col gap-1">
                <a href="mailto:s.jenkins@elitemfg.com" class="text-sm text-blue-600 hover:underline flex items-center gap-1.5">
                  <i data-lucide="mail" class="w-3.5 h-3.5"></i> s.jenkins@elitemfg.com
                </a>
                <div class="text-sm text-slate-600 flex items-center gap-1.5">
                  <i data-lucide="phone" class="w-3.5 h-3.5 text-slate-400"></i> +1 (555) 123-4567
                </div>
              </div>
            </td>
            <td class="px-6 py-4 text-sm text-slate-500">
              Jan 12, 2026
            </td>
            <td class="px-6 py-4 text-right">
              <div class="flex justify-end gap-2">
                <button title="Edit" class="p-2 hover:bg-slate-100 rounded-lg text-slate-400 hover:text-slate-900 transition-colors">
                  <i data-lucide="edit-3" class="w-4 h-4"></i>
                </button>
                <button title="View History" class="p-2 hover:bg-slate-100 rounded-lg text-slate-400 hover:text-slate-900 transition-colors">
                  <i data-lucide="external-link" class="w-4 h-4"></i>
                </button>
              </div>
            </td>
          </tr>
          </tbody>
      </table>
    </div>
  </div>
</div>