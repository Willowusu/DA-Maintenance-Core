<div class="card w-full max-w-md shadow-2xl border border-slate-200 rounded-2xl bg-white overflow-hidden mx-auto">
    <div class="bg-slate-50 border-b border-slate-100 p-6 text-center">
        <div class="inline-flex items-center justify-center w-12 h-12 rounded-lg bg-slate-900 text-white mb-3">
            <i data-lucide="shield-check" class="w-6 h-6"></i>
        </div>
        <h3 class="text-xl font-bold text-slate-900 tracking-tight">DA Maintenance</h3>
        <p class="text-xs font-semibold uppercase tracking-widest text-slate-500">Admin Control Center</p>
    </div>

    <div class="p-8">
        <div id="alert-container" class="mb-6 hidden transition-all duration-300"></div>

        <div id="login-section">
            <header class="mb-8">
                <h2 class="text-2xl font-semibold text-slate-800">Login</h2>
                <p class="text-sm text-slate-500 mt-1">Enter your number to receive a secure OTP.</p>
            </header>
            <form id="request-otp-form" class="grid gap-5">
                <div class="grid gap-2">
                    <label for="phone_number" class="text-sm font-medium text-slate-700">Phone Number</label>
                    <div class="flex">
                        <div class="inline-flex items-center px-3 rounded-l-md border border-r-0 border-slate-300 bg-slate-50 text-slate-500 sm:text-sm gap-2">
                            <img src="https://flagcdn.com/w20/gh.png" alt="Ghana Flag" class="w-5 h-auto">
                            <span class="font-medium text-slate-700">+233</span>
                        </div>
                        <input type="tel" id="phone_number" placeholder="24 123 4567" required
                            class="flex-1 block w-full px-3 py-2 rounded-none rounded-r-md border border-slate-300 focus:ring-2 focus:ring-slate-900 outline-none transition-all">
                    </div>
                </div>
                <button type="submit" id="btn-request" class="w-full bg-slate-900 text-white font-medium py-2.5 rounded-md shadow-lg active:scale-95 transition-all">
                    Send OTP
                </button>
            </form>
        </div>

        <div id="otp-section" class="hidden">
            <header class="mb-8">
                <h2 class="text-2xl font-semibold text-slate-800">Verify OTP</h2>
                <p class="text-sm text-slate-500 mt-1">Enter the 6-digit code sent to your phone.</p>
            </header>
            <form id="verify-otp-form" class="grid gap-5">
                <input type="text" id="otp-code" maxlength="6" placeholder="0 0 0 0 0 0" required
                    class="text-center text-3xl font-mono tracking-[0.75em] w-full px-3 py-4 border-2 border-slate-300 rounded-xl focus:ring-2 focus:ring-slate-900 outline-none bg-slate-50/50">
                
                <button type="submit" id="btn-verify" class="w-full bg-blue-600 text-white font-medium py-2.5 rounded-md shadow-lg active:scale-95 transition-all">
                    Verify & Login
                </button>

                <div class="text-center space-y-3">
                    <p class="text-sm text-slate-500">
                        Didn't get code? <button type="button" id="btn-resend" class="text-blue-600 font-bold disabled:text-slate-400" disabled>Resend <span id="timer">(60s)</span></button>
                    </p>
                    <button type="button" id="btn-back" class="text-xs text-slate-400 hover:text-slate-600">← Back to login</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
$(document).ready(function() {
    lucide.createIcons();
    let countdown;

    // Helper: Dynamic Alert
    const showAlert = (type, title, desc) => {
        const isError = type === 'danger' || type === 'error';
        const alertHtml = `
            <div class="${isError ? 'alert-destructive' : 'alert'} shadow-sm animate-in fade-in slide-in-from-top-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/></svg>
                <div>
                    <h2 class="font-bold text-sm">${title}</h2>
                    <section class="text-xs">${desc}</section>
                </div>
            </div>`;
        $('#alert-container').html(alertHtml).hide().slideDown(200);
        setTimeout(() => $('#alert-container').slideUp(200), 5000);
    };

    function startTimer() {
        let sec = 60;
        $('#btn-resend').prop('disabled', true);
        countdown = setInterval(() => {
            sec--;
            $('#timer').text(`(${sec}s)`);
            if (sec <= 0) { clearInterval(countdown); $('#btn-resend').prop('disabled', false); $('#timer').text(''); }
        }, 1000);
    }

    // AUTH STEP 1: Request OTP
    $('#request-otp-form').on('submit', function(e) {
        e.preventDefault();
        const rawNum = $('#phone_number').val().trim().replace(/^0/, '');
        const fullNum = "233" + rawNum; // CONCATENATED COUNTRY CODE

        $('#btn-request').prop('disabled', true).text('Sending...');

        $.ajax({
            url: '/api/v1/auth/request-otp',
            method: 'POST',
            data: { phone_number: fullNum },
            success: function(res) {
                if (res.status === 'success') {
                    showAlert('success', 'OTP Sent', `Code sent to +233 ${rawNum}`);
                    startTimer();
                    setTimeout(() => {
                        $('#login-section').fadeOut(300, () => $('#otp-section').fadeIn(300).removeClass('hidden'));
                    }, 600);
                } else {
                    showAlert('error', 'Failed', res.message);
                    $('#btn-request').prop('disabled', false).text('Send OTP');
                }
            },
            error: () => {
                showAlert('error', 'Connection Error', 'Server unreachable.');
                $('#btn-request').prop('disabled', false).text('Send OTP');
            }
        });
    });

    // AUTH STEP 2: Verify OTP
    $('#verify-otp-form').on('submit', function(e) {
        e.preventDefault();
        const rawNum = $('#phone_number').val().trim().replace(/^0/, '');
        const fullNum = "233" + rawNum;

        $('#btn-verify').prop('disabled', true).text('Verifying...');

        $.ajax({
            url: '/api/v1/auth/verify-otp',
            method: 'POST',
            data: { phone_number: fullNum, otp: $('#otp-code').val() },
            success: function(res) {
                if (res.data?.token) {
                    localStorage.setItem('admin_token', res.data.token);
                    showAlert('success', 'Success', 'Redirecting...');
                    setTimeout(() => window.location.href = '/admin/summary', 800);
                }
            },
            error: (err) => {
                showAlert('error', 'Invalid OTP', err.responseJSON?.message || 'Try again.');
                $('#btn-verify').prop('disabled', false).text('Verify & Login');
            }
        });
    });

    $('#btn-back').click(() => {
        $('#otp-section').fadeOut(300, () => $('#login-section').fadeIn(300));
        $('#btn-request').prop('disabled', false).text('Send OTP');
    });
});
</script>